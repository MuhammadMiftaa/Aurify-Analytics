{
  "name": "refina-analytics",
  "version": "1.0.0",
  "description": "Analytics service for financial data aggregation and reporting",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc && node fix-imports.mjs",
    "start:ts": "tsx src/main.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "analytics",
    "financial",
    "mongodb",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@muhammadmiftaa/refina-protobuf": "github:MuhammadMiftaa/Aurify-Protobuf#v1.13.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.19.0",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
